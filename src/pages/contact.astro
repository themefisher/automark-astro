                <path opacity="0.4" d="M15.5306 4.64466C18.7902 4.56287 21.2119 4.56286 24.4716 4.64466L24.5963 4.64778C27.1119 4.71084 29.1817 4.76273 30.85 5.05291C31.4671 5.16025 32.0492 5.30304 32.599 5.49683C32.745 5.5312 32.8853 5.58504 33.0161 5.65647C33.8759 6.01281 34.6532 6.51211 35.3588 7.21955C36.6079 8.47183 37.206 9.93099 37.509 11.6736L33.7603 13.6021C33.575 13.6678 33.3423 13.7996 33.027 13.9783L25.9673 17.9783C23.8013 19.2056 21.9694 20 20.0007 20C18.0321 20 16.2002 19.2056 14.0342 17.9783L6.97515 13.9786C6.65928 13.7996 6.42631 13.6676 6.24085 13.6021L2.49316 11.6736C2.79615 9.93098 3.39424 8.47182 4.64333 7.21954C5.89901 5.96066 7.38153 5.36088 9.15214 5.0529C10.8204 4.76273 12.8902 4.71085 15.4058 4.64779L15.5306 4.64466Z" fill="white" />
              </svg>
            </div>
            <div class="flex flex-col gap-3">
              <h3 class="font-secondary font-bold text-2xl text-text-white">Email Us</h3>
              <p class="text-text text-lg">automark@gmail.com</p>
            </div>
          </div>

          <!-- Phone Card -->
          <div class="flex flex-col gap-5 p-7 md:p-8 bg-white/5 rounded-2xl">
            <div class="w-10 h-10">

                <path d="M11.2564 4.12747C16.9114 2.51293 23.0872 2.51293 28.7422 4.12747C31.0645 4.79049 32.7575 5.62214 34.3028 6.6259C37.0578 8.41545 38.1742 11.595 37.8658 14.5547C37.7753 15.4232 37.3571 16.1931 36.6332 16.6585C35.9214 17.116 35.068 17.1809 34.2798 16.9618C34.1076 16.914 33.9337 16.866 33.7587 16.8177C33.1606 16.6525 32.5492 16.4837 31.9445 16.3044C30.744 15.9483 29.7446 15.4856 29.0502 14.6048C28.3748 13.7481 28.1347 12.6742 27.9753 11.4995L27.4341 7.51329C27.4072 7.31502 27.3937 7.21588 27.33 7.14655C27.2663 7.07722 27.1699 7.05574 26.9771 7.01279C22.412 5.9956 17.5865 5.9956 13.0215 7.01279C12.8287 7.05574 12.7323 7.07722 12.6686 7.14655C12.6049 7.21588 12.5914 7.31502 12.5645 7.51329L12.0233 11.4995C11.8639 12.6742 11.6238 13.7481 10.9484 14.6048C10.254 15.4856 9.25462 15.9483 8.0541 16.3044C7.44939 16.4837 6.83807 16.6525 6.23994 16.8177L6.23791 16.8182C6.06359 16.8663 5.89039 16.9142 5.7188 16.9618C4.9306 17.1809 4.07715 17.116 3.36542 16.6585C2.64152 16.1931 2.22332 15.4232 2.13281 14.5547C1.82438 11.595 2.94084 8.41545 5.69579 6.6259C7.24104 5.62214 8.93408 4.79049 11.2564 4.12747Z" fill="white" />
              </svg>
            </div>
            <div class="flex flex-col gap-3">
              <h3 class="font-secondary font-bold text-2xl text-text-white">Call Us</h3>
              <p class="text-text text-lg">+1 (800) 321-9876</p>
            </div>
          </div>

          <!-- Calendar Card -->
          <div class="flex flex-col gap-5 p-7 md:p-8 bg-white/5 rounded-2xl">
            <div class="w-10 h-10">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path opacity="0.4" fill-rule="evenodd" clip-rule="evenodd" d="M16.667 21.6667C16.667 20.7462 17.4132 20 18.3337 20H26.667C27.5875 20 28.3337 20.7462 28.3337 21.6667C28.3337 22.5871 27.5875 23.3333 26.667 23.3333H18.3337C17.4132 23.3333 16.667 22.5871 16.667 21.6667ZM11.667 21.6667C11.667 20.7462 12.4132 20 13.3337 20H13.3486C14.2691 20 15.0153 20.7462 15.0153 21.6667C15.0153 22.5871 14.2691 23.3333 13.3486 23.3333H13.3337C12.4132 23.3333 11.667 22.5871 11.667 21.6667ZM11.667 28.3333C11.667 27.4129 12.4132 26.6667 13.3337 26.6667H21.667C22.5875 26.6667 23.3337 27.4129 23.3337 28.3333C23.3337 29.2538 22.5875 30 21.667 30H13.3337C12.4132 30 11.667 29.2538 11.667 28.3333ZM24.9854 28.3333C24.9854 27.4129 25.7315 26.6667 26.652 26.6667H26.667C27.5875 26.6667 28.3337 27.4129 28.3337 28.3333C28.3337 29.2538 27.5875 30 26.667 30H26.652C25.7315 30 24.9854 29.2538 24.9854 28.3333Z" fill="white" />

---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/layouts/components/PageHeader.astro";
import Faq from "@/layouts/components/Faq.astro";
import CallToAction from "@/layouts/components/CallToAction.astro";
import { getEntry } from "astro:content";

const contact = await getEntry("contact", "-index");
const d = contact!.data as any;
---

<Base title={d.title} meta_title={d.meta_title} description={d.description}>

<PageHeader title={d.page_header.title} />

<!-- Contact Section -->
<section class="section pt-0">
  <div class="container">
    <div class="row g-7 max-lg:gap-5">
      <!-- Left Column - Contact Cards -->
      <div class="col-12 lg:col-5">
        <div class="flex flex-col gap-5">
          <!-- Email Card -->
          <div class="flex flex-col gap-5 p-7 md:p-8 bg-white/5 rounded-2xl">
            <div class="w-10 h-10">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">

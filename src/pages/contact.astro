              </svg>
            </div>
            <div class="flex flex-col gap-3">
              <h3 class="font-secondary font-bold text-2xl text-text-white">Book A Meeting</h3>
              <p class="text-text text-lg">calendar.app.google</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column - Contact Form -->
      <div class="col-12 lg:col-7">
        <div class="p-8 md:p-10 bg-white/5 rounded-2xl">
          <form class="flex flex-col gap-10">
            <div class="flex flex-col gap-5">
              <div class="relative">
                <input type="text" placeholder="Name" required class="w-full rounded-full bg-white/5 backdrop-blur-[44px] px-8 py-5 border border-border text-text-white placeholder:text-text-dark focus:border-primary focus:outline-none transition-colors" />
              </div>
              <div class="relative">
                <input type="email" placeholder="Email Address" required class="w-full rounded-full bg-white/5 backdrop-blur-[44px] px-8 py-5 border border-border text-text-white placeholder:text-text-dark focus:border-primary focus:outline-none transition-colors" />
              </div>
              <div class="relative">
                <input type="tel" placeholder="Phone number" required class="w-full rounded-full bg-white/5 backdrop-blur-[44px] px-8 py-5 border border-border text-text-white placeholder:text-text-dark focus:border-primary focus:outline-none transition-colors" />
              </div>
              <div class="relative">
                <textarea placeholder="Write your message..." rows="4" required class="w-full rounded-[20px] bg-white/5 backdrop-blur-[44px] px-8 py-5 border border-border text-text-white placeholder:text-text-dark focus:border-primary focus:outline-none transition-colors resize-none"></textarea>
              </div>
            </div>
            <div class="flex flex-col gap-6">
              <div class="flex items-start gap-3">
                <input type="checkbox" id="recaptcha-terms" required class="w-6 h-6 mt-0.5 rounded border-border bg-white/5 text-primary focus:ring-primary focus:ring-offset-0" />
                <label for="recaptcha-terms" class="text-text text-base leading-relaxed cursor-pointer">
                  This site is protected by reCAPTCHA and the Google Privacy Policy and Terms of Service apply.
                </label>
              </div>
              <button type="submit" class="btn btn-primary w-full py-4 text-lg font-medium">
                Send Message
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<Faq />

<!-- Call to Action -->
<CallToAction />
</Base>

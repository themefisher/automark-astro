---
import GradientBlob from "@/components/GradientBlob.astro";
import TestimonialCard from "@/components/TestimonialCard.astro";
import { getEntry } from "astro:content";

const testimonials = await getEntry("testimonialSection", "testimonial");
const testimonialData = testimonials?.data;
---

{
  testimonialData?.enable && (
    <section class="section relative">
      <div class="container">
        <div class="section-container">
          <div class="section-intro centralize">
            <h2 class="title hasHighlight" set:html={testimonialData?.title} />
          </div>
          <div class="section-content">
            <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-7">
              {testimonialData?.testimonials.map((item: any) => (
                <TestimonialCard
                  poster={item.poster}
                  name={item.name}
                  designation={item.designation}
                  content={item.content}
                  video={item.video}
                />
              ))}
            </div>
          </div>
        </div>
      </div>
      <GradientBlob />
    </section>
  )
}

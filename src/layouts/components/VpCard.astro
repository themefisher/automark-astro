---
import ImageMod from "@/layouts/components/ImageMod.astro";
interface Props {
  logo: string;
  title: string;
}
const { logo, title } = Astro.props;
---
<div class="p-8 rounded-2xl bg-text-white/5">
  <ImageMod src={logo} alt={`${title} icon`} class="mb-6" />
  <h3 class="text-h5-sm font-bold">{title}</h3>
  <ul class="stars-list mt-5 text-text-dark">
    <li>AI-powered lead scoring</li>
    <li>Automated follow-ups designed to help</li>
    <li>Prevent prospects from being overlooked</li>
  </ul>
</div>

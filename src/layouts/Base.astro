---
import TwSizeIndicator from "@/components/TwSizeIndicator.astro";
import config from "@/config/config.json";
import theme from "@/config/theme.json";
import { plainify } from "@/lib/utils/textConverter";
import Footer from "@/partials/Footer.astro";
import Header from "@/partials/Header.astro";
import "@/styles/main.css";
import {
  GoogleTagmanager,
  GoogleTagmanagerNoscript,
} from "@digi4care/astro-google-tagmanager";
import { Font } from "astro:assets";
// ClientRouter removed: module scripts + View Transitions don't mix well with third-party CDN libs

const fontEntries = Object.entries(theme.fonts.font_family).filter(
  ([key]) => !key.includes("_type"),
);

export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
}

const { title, meta_title, description, image, noindex, canonical } =
  Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    {
      config.google_tag_manager.enable && (
        <GoogleTagmanager id={config.google_tag_manager.gtm_id} />
      )
    }
    <link rel="shortcut icon" href={config.site.favicon} />
    <meta name="theme-name" content="astroplate" />
    <meta name="msapplication-TileColor" content="#000000" />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content="#fff"
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#000"
    />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />

    {
      fontEntries.map(([key]) => {
        const cssVar = `--font-${key}` as any;
        return <Font cssVariable={cssVar} preload />;
      })
    }

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=5"
    />

    <title>
      {plainify(meta_title ? meta_title : title ? title : config.site.title)}
    </title>

    {canonical && <link rel="canonical" href={canonical} item-prop="url" />}
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <meta
      name="description"
      content={plainify(
        description ? description : config.metadata.meta_description,
      )}
    />

    <!-- View Transitions removed to avoid conflicts with GSAP/Lenis/Swiper -->

    <meta name="author" content={config.metadata.meta_author} />
    <meta
      property="og:title"
      content={plainify(
        meta_title ? meta_title : title ? title : config.site.title,
      )}
    />
    <meta
      property="og:description"
      content={plainify(
        description ? description : config.metadata.meta_description,
      )}
    />
    <meta property="og:type" content="website" />
    <meta
      property="og:url"
      content={`${config.site.base_url}/${Astro.url.pathname.replace("/", "")}`}
    />
    <meta
      name="twitter:title"
      content={plainify(
        meta_title ? meta_title : title ? title : config.site.title,
      )}
    />
    <meta
      name="twitter:description"
      content={plainify(
        description ? description : config.metadata.meta_description,
      )}
    />
    <meta
      property="og:image"
      content={`${config.site.base_url}${
        image ? image : config.metadata.meta_image
      }`}
    />
    <meta
      name="twitter:image"
      content={`${config.site.base_url}${
        image ? image : config.metadata.meta_image
      }`}
    />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Lenis Stylesheet -->
    <link rel="stylesheet" href="https://unpkg.com/lenis@1.3.17/dist/lenis.css">

    <!-- Lazy load: Swipper css, Fontawesome css -->
    <script is:inline>
    // @ts-nocheck
    window.addEventListener('load', function() {
      const links = [
        {
          href: 'https://cdnjs.cloudflare.com/ajax/libs/Swiper/11.0.5/swiper-bundle.min.css',
          integrity: 'sha512-rd0qOHVMOcez6pLWPVFIv7EfSdGKLt+eafXh4RO/12Fgr41hDQxfGvoi1Vy55QIVcQEujUE1LQrATCLl2Fs+ag==',
          crossOrigin: 'anonymous'
        },
        {
          href: 'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css'
        }
      ];
      links.forEach(linkData => {
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = linkData.href;
        if (linkData.integrity) link.integrity = linkData.integrity;
        if (linkData.crossOrigin) link.crossOrigin = linkData.crossOrigin;
        document.head.appendChild(link);
      });
    });
    </script>
  </head>
  <body>
    {
      config.google_tag_manager.enable && (
        <GoogleTagmanagerNoscript id={config.google_tag_manager.gtm_id} />
      )
    }

    {/* <TwSizeIndicator /> */}
    <Header />
    <main id="main-content" class="overflow-x-hidden md:overflow-x-auto">
      <slot />
    </main>
    <Footer />

    <!-- Swiper JS -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/Swiper/11.0.5/swiper-bundle.min.js" integrity="sha512-Ysw1DcK1P+uYLqprEAzNQJP+J4hTx4t/3X2nbVwszao8wD+9afLjBQYjz7Uk4ADP+Er++mJoScI42ueGtQOzEA==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <!-- GSAP CDN -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/gsap.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/ScrollTrigger.min.js"></script>
    <!-- LENIS CDN -->
    <script is:inline src="https://unpkg.com/lenis@1.3.17/dist/lenis.min.js"></script>
    <!-- Main Script (runs sync since DOM is already parsed at end of body) -->
    <script is:inline src="/scripts/main.js"></script>
    <!-- Animations Script (ES module with GSAP/Lenis/spores) -->
    <script is:inline type="module" src="/scripts/animations.js"></script>
  </body>
</html>
